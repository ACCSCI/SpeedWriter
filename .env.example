# InkOS Environment Configuration
# Copy to .env and fill in your values
# .env is gitignored, never commit your real keys!

# === LLM Provider ===
# Options: openai, anthropic, MiniMax, deepseek, moonshot, custom
INKOS_LLM_PROVIDER=MiniMax

# === MiniMax Provider(默认,OpenAI 兼容协议) ===
# 文档:https://platform.minimaxi.com/docs
# 申请 key:https://platform.minimaxi.com/user-center/basic-information/Interface-key
INKOS_LLM_BASE_URL=https://api.minimaxi.com/v1
INKOS_LLM_MODEL=MiniMax-Text-01
# INKOS_LLM_API_KEY=  ← 填你自己的 key,本地开发用

# === OpenAI Provider(备选) ===
# INKOS_LLM_BASE_URL=https://api.openai.com/v1
# INKOS_LLM_MODEL=gpt-4o
# INKOS_LLM_API_KEY=sk-...

# === Anthropic Provider(备选) ===
# INKOS_LLM_PROVIDER=anthropic
# INKOS_LLM_BASE_URL=https://api.anthropic.com
# INKOS_LLM_MODEL=claude-sonnet-4-5
# INKOS_LLM_API_KEY=sk-ant-...

# === DeepSeek Provider(便宜) ===
# INKOS_LLM_BASE_URL=https://api.deepseek.com/v1
# INKOS_LLM_MODEL=deepseek-chat
# INKOS_LLM_API_KEY=sk-...

# === Notifications(可选) ===
INKOS_TELEGRAM_BOT_TOKEN=
INKOS_TELEGRAM_CHAT_ID=
INKOS_FEISHU_WEBHOOK_URL=
INKOS_WECOM_WEBHOOK_URL=

# === E2E 测试专用(Playwright 读这些) ===
# E2E_LLM_API_KEY=
# E2E_LLM_BASE_URL=
# E2E_LLM_MODEL=
